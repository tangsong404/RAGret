# Copy to .env in the repo root and fill in values (`.env` is gitignored).

# HTTP server (ragret serve)
RAGRET_HOST=127.0.0.1
RAGRET_PORT=8765

# Quick Q&A LangGraph agent — one provider: openai (default) or anthropic
# Use RAGRET_LLM_PROVIDER (RAGRET_LLM_TYPE is accepted as a legacy alias).
# RAGRET_LLM_PROVIDER=openai
RAGRET_LLM_BASE_URL=https://your-api.example.com/v1
RAGRET_LLM_MODEL=your-model-name
RAGRET_LLM_API_KEY=your-api-key
# Anthropic example (base_url optional):
# RAGRET_LLM_PROVIDER=anthropic
# RAGRET_LLM_MODEL=claude-sonnet-4-20250514
# RAGRET_LLM_API_KEY=your-anthropic-key

# Optional: image ingest for corpus build (default off; when off, images behave like legacy)
# RAGRET_IMAGE_INGEST_ENABLED=false
# Word/PDF embedded EMF/WMF are converted to PNG via Pillow, then ImageMagick, Inkscape, or LibreOffice (PATH).
# Linux/Docker: install one of `imagemagick`, `inkscape`, or `libreoffice` for EMF/WMF support.
# Vision API for captions when image ingest is on (separate from Quick Q&A LLM above)
# RAGRET_VISION_PROVIDER=openai
# RAGRET_VISION_BASE_URL=https://your-api.example.com/v1
# RAGRET_VISION_MODEL=your-vision-model
# RAGRET_VISION_API_KEY=your-vision-api-key

# Optional paths
# RAGRET_REGISTRY=./runtime/ragret_registry.json
# RAGRET_APP_DB=./runtime/app.sqlite
# RAGRET_API_TOKEN=
# RAGRET_PUBLIC_HOST=https://ragret.example.com
