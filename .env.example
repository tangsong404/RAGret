# Copy to .env in the repo root and fill in values (`.env` is gitignored).

# HTTP server (ragret serve)
RAGRET_HOST=127.0.0.1
RAGRET_PORT=8765

# Quick Q&A LangGraph agent (OpenAI-compatible API)
RAGRET_LLM_BASE_URL=https://your-api.example.com/v1
RAGRET_LLM_MODEL=your-model-name
RAGRET_LLM_API_KEY=your-api-key

# Optional paths
# RAGRET_REGISTRY=./runtime/ragret_registry.json
# RAGRET_APP_DB=./runtime/app.sqlite
# RAGRET_API_TOKEN=
